data/raw/
data/raw_cb_a/
data/point_data/*.xlsx
!data/paper_reference/
data/paper_reference/*.bak

# Antenna patterns, TX-power CSVs (campaign-specific, user provides)
matlab/patterns/*.DAT
matlab/patterns/*.dat
matlab/patterns/*.mat
matlab/processing/nyu_142/*.csv
matlab/processing/nyu_7/*.csv
matlab/processing/nyu_7/*.mat
matlab/processing/usc_145/*.mat
matlab/processing/usc_7/*.mat

