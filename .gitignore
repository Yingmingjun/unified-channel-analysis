# ---------------------------------------------------------------------------
# User-staged measurement data (never commit)
# ---------------------------------------------------------------------------
data/raw/
data/raw_cb_a/
data/point_data/*.xlsx
# Whitelist the 6 canonical per-link point-data tables (aggregate scalar
# summaries) so clones can run the figure/table scripts out of the box.
!data/point_data/N1_142_UMi.xlsx
!data/point_data/N1_7_UMi.xlsx
!data/point_data/N3_142_UMi.xlsx
!data/point_data/N3_7_UMi.xlsx
!data/point_data/U3_142_UMi.xlsx
!data/point_data/U3_7_UMi.xlsx
!data/paper_reference/
data/paper_reference/*.bak

# Antenna patterns, TX-power CSVs (campaign-specific, user provides)
matlab/patterns/*.DAT
matlab/patterns/*.dat
matlab/patterns/*.mat
matlab/processing/nyu_142/*.csv
matlab/processing/nyu_7/*.csv
matlab/processing/nyu_7/*.mat
matlab/processing/usc_145/*.mat
matlab/processing/usc_7/*.mat

# ---------------------------------------------------------------------------
# Pipeline outputs (regenerated by run_all)
# ---------------------------------------------------------------------------
matlab/processing/*/Results/*
# Whitelist the specific aggregate per-link Results files so clones can
# reproduce the paper. pas_store buffers are stripped from the .mat's.
!matlab/processing/nyu_142/Results/all_comparison_results.mat
!matlab/processing/nyu_142/Results/NYU142GHz_Method_Comparison_Results.csv
!matlab/processing/nyu_7/Results/all_comparison_results.mat
!matlab/processing/nyu_7/Results/NYU7GHz_Method_Comparison_Results.csv
!matlab/processing/usc_145/Results/USC145GHz_Full_Results.mat
!matlab/processing/usc_145/Results/USC145GHz_Full_Results.csv
!matlab/processing/usc_7/Results/USC7GHz_Full_Results.mat
!matlab/processing/usc_7/Results/USC7GHz_NewData_Results.csv
matlab/processing/*/Figures/
figures/matlab/
docs/paper_parity_*.md

# ---------------------------------------------------------------------------
# MATLAB
# ---------------------------------------------------------------------------
*.asv          # autosave
*.mat~         # MATLAB backup
slprj/
.idea/
.vs/

# ---------------------------------------------------------------------------
# Editors / OS
# ---------------------------------------------------------------------------
.vscode/
.idea/
*.swp
*.swo
.DS_Store
Thumbs.db
desktop.ini
